{
  "name": "keryx-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev",
    "build": "bun run generate && vitepress build",
    "preview": "vitepress preview",
    "generate": "bun run scripts/generate-docs-data.ts",
    "lint": "biome check --files-ignore-unknown=true . && prettier --check \"**/*.md\"",
    "format": "biome check --write --files-ignore-unknown=true . && prettier --write \"**/*.md\"",
    "test": "bun run build && bun test"
  },
  "dependencies": {
    "vitepress": "^1.6.3",
    "vue": "^3.5.13",
    "vitepress-plugin-llms": "^1.1.0"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "ts-morph": "^25.0.0"
  }
}
