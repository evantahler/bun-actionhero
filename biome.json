{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/types/",
      "!**/.cache/**",
      "!**/docs/.vitepress/dist",
      "!**/docs/.vitepress/cache",
      "!**/docs/.vitepress/data",
      "!**/example/frontend/.next",
      "!**/bun.lockb",
      "!**/*.md",
      "!**/templates/**"
    ]
  }
}
