{
  "name": "keryx",
  "version": "0.21.0",
  "module": "index.ts",
  "type": "module",
  "license": "MIT",
  "description": "The fullstack TypeScript framework for MCP and APIs — write one action, serve HTTP, WebSocket, CLI, background tasks, and MCP tools.",
  "author": "Evan Tahler <evan@evantahler.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actionhero/keryx.git",
    "directory": "packages/keryx"
  },
  "homepage": "https://keryxjs.com",
  "bugs": {
    "url": "https://github.com/actionhero/keryx/issues"
  },
  "keywords": [
    "api",
    "framework",
    "bun",
    "typescript",
    "websocket",
    "realtime",
    "mcp",
    "model-context-protocol",
    "cli",
    "ai",
    "ai-agents",
    "mcp-server",
    "oauth2",
    "tool-calling",
    "llm",
    "fullstack",
    "transport-agnostic",
    "actionhero"
  ],
  "files": [
    "actions/",
    "classes/",
    "config/",
    "initializers/",
    "lua/",
    "middleware/",
    "servers/",
    "templates/",
    "util/",
    "api.ts",
    "index.ts",
    "keryx.ts",
    "migrations.ts",
    "tsconfig.json",
    "LICENSE"
  ],
  "bin": {
    "keryx": "keryx.ts"
  },
  "exports": {
    ".": "./index.ts",
    "./classes/*": "./classes/*",
    "./initializers/*": "./initializers/*",
    "./actions/*": "./actions/*",
    "./middleware/*": "./middleware/*",
    "./util/*": "./util/*",
    "./config": "./config/index.ts",
    "./config/*": "./config/*",
    "./servers/*": "./servers/*"
  },
  "scripts": {
    "start": "bun keryx.ts start",
    "dev": "bun --watch keryx.ts start",
    "migrations": "bun run migrations.ts",
    "test": "tsc && bun test",
    "compile": "bun build keryx.ts --compile --outfile keryx",
    "lint": "tsc && biome check .",
    "format": "tsc && biome check --write .",
    "prepublishOnly": "cp ../../README.md ."
  },
  "dependencies": {
    "@kubiks/otel-drizzle": "^2.1.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.0.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.200.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "@types/cookie": "^0.6.0",
    "@types/mustache": "^4.2.6",
    "@types/pg": "^8.16.0",
    "colors": "^1.4.0",
    "commander": "^12.1.0",
    "cookie": "^0.6.0",
    "ioredis": "^5.9.2",
    "mustache": "^4.2.0",
    "node-resque": "^9.5.0",
    "pg": "^8.18.0",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.1.8",
    "@types/formidable": "^3.4.6",
    "drizzle-kit": "^0.31.9",
    "drizzle-zod": "^0.8.3"
  }
}
